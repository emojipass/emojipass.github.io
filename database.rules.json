{
  "rules": {
    ".read": false,
    ".write": false,
    "users": {
      "$username": {
        ".read": "auth != null",
        ".write": "auth != null && $username.matches(/^[A-Za-z0-9 _-]{3,64}$/)",
        "meta": {
          ".validate": "newData.hasChildren(['username','password_type','generated_password','created_at']) && newData.child('username').isString() && newData.child('username').val() === $username && newData.child('password_type').isString() && (newData.child('password_type').val() === 'emoji' || newData.child('password_type').val() === 'digits') && newData.child('generated_password').isString() && newData.child('created_at').isString()"
        },
        "passwords": {
          "$type": {
            ".validate": "($type === 'emoji' || $type === 'digits') && newData.hasChildren(['generated_password','created_at']) && newData.child('generated_password').isString() && newData.child('created_at').isString()"
          }
        },
        "events": {
          "$eventId": {
            ".validate": "newData.hasChildren(['condition','attempt_number','success','duration_ms','timestamp']) && newData.child('condition').isString() && (newData.child('condition').val() === 'emoji' || newData.child('condition').val() === 'digits') && newData.child('attempt_number').isNumber() && newData.child('success').isBoolean() && newData.child('duration_ms').isNumber() && newData.child('timestamp').isString()"
          }
        },
        "metrics": {
          ".validate": "newData.hasChildren(['login_attempts_total','login_success_count','login_failure_count','success_rate','first_attempt_success']) && newData.child('login_attempts_total').isNumber() && newData.child('login_success_count').isNumber() && newData.child('login_failure_count').isNumber() && newData.child('success_rate').isNumber() && (newData.child('first_attempt_success').isBoolean() || newData.child('first_attempt_success').val() === null) && (!newData.child('last_attempt_at').exists() || newData.child('last_attempt_at').isString())"
        },
        "$other": {
          ".validate": false
        }
      }
    }
  }
}